# Raw datasets (never committed — CLAUDE.md > Security)
datasets/
prompt.txt
CLAUDE.md

# Environments / tooling
.venv/
.claude/

# Python bytecode / caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Pipeline artefacts (regenerated; never committed).
# Root-anchored (leading /): an unanchored `models/` also ignored the
# src/models/ production package, silently keeping every model wrapper
# out of version control.
data/interim/
data/processed/
data/features/
data/metadata/
/models/
/outputs/

# Keep empty stage dirs tracked
!**/.gitkeep

# Web frontend (Node) — dependencies and build output are regenerated.
webapp/server/node_modules/
webapp/frontend/node_modules/
webapp/frontend/dist/

# Live-integration local secrets/inventory — NEVER commit (may contain hosts,
# usernames, host keys). Credentials themselves always come from env vars.
configs/*.local.yaml
configs/known_hosts.local
